@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(Merlin_VERSION "@PROJECT_VERSION@")
set(Merlin_WITH_VULKAN @MERLIN_ENABLE_VULKAN@)

if(Merlin_WITH_VULKAN)
  find_dependency(Vulkan 1.2)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/MerlinTargets.cmake")

set(Merlin_RenderWorld_FOUND TRUE)
set(Merlin_RenderExtraction_FOUND TRUE)
set(Merlin_Vulkan_FOUND FALSE)
if(TARGET Merlin::Vulkan)
  set(Merlin_Vulkan_FOUND TRUE)
endif()

set(_merlin_known_components RenderWorld RenderExtraction Vulkan)
foreach(_merlin_component IN LISTS Merlin_FIND_COMPONENTS)
  if(NOT _merlin_component IN_LIST _merlin_known_components)
    set(Merlin_${_merlin_component}_FOUND FALSE)
  endif()
endforeach()

check_required_components(Merlin)
