@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(Merlin_VERSION "@PROJECT_VERSION@")
set(Merlin_WITH_VULKAN @MERLIN_ENABLE_VULKAN@)
set(Merlin_VULKAN_MIN_VERSION "@MERLIN_VULKAN_MIN_VERSION@")
set(Merlin_WITH_MATERIALX @MERLIN_ENABLE_MATERIALX@)
set(Merlin_MATERIALX_MIN_VERSION "@MERLIN_MATERIALX_MIN_VERSION@")

include("${CMAKE_CURRENT_LIST_DIR}/MerlinTargets.cmake")

set(Merlin_RenderWorld_FOUND TRUE)
set(Merlin_RenderExtraction_FOUND TRUE)
set(Merlin_RenderBackend_FOUND TRUE)
set(Merlin_Vulkan_FOUND FALSE)
set(Merlin_MaterialX_FOUND FALSE)

set(_merlin_load_vulkan FALSE)
if(Merlin_WITH_VULKAN)
  if(NOT Merlin_FIND_COMPONENTS OR Vulkan IN_LIST Merlin_FIND_COMPONENTS)
    set(_merlin_load_vulkan TRUE)
  endif()
endif()

if(_merlin_load_vulkan)
  if(Merlin_FIND_REQUIRED_Vulkan)
    find_dependency(Vulkan ${Merlin_VULKAN_MIN_VERSION})
  else()
    find_package(Vulkan ${Merlin_VULKAN_MIN_VERSION} QUIET)
  endif()

  if(Vulkan_FOUND)
    include("${CMAKE_CURRENT_LIST_DIR}/MerlinVulkanTargets.cmake")
    set(Merlin_Vulkan_FOUND TRUE)
  endif()
endif()

set(_merlin_load_materialx FALSE)
if(Merlin_WITH_MATERIALX)
  if(NOT Merlin_FIND_COMPONENTS OR MaterialX IN_LIST Merlin_FIND_COMPONENTS)
    set(_merlin_load_materialx TRUE)
  endif()
endif()

if(_merlin_load_materialx)
  if(Merlin_FIND_REQUIRED_MaterialX)
    find_dependency(MaterialX ${Merlin_MATERIALX_MIN_VERSION} CONFIG)
  else()
    find_package(MaterialX ${Merlin_MATERIALX_MIN_VERSION} CONFIG QUIET)
  endif()

  if(MaterialX_FOUND AND TARGET MaterialXGenSlang)
    include("${CMAKE_CURRENT_LIST_DIR}/MerlinMaterialXTargets.cmake")
    set(Merlin_MaterialX_FOUND TRUE)
  endif()
endif()

set(_merlin_known_components
    RenderWorld RenderExtraction RenderBackend Vulkan MaterialX)
foreach(_merlin_component IN LISTS Merlin_FIND_COMPONENTS)
  if(NOT _merlin_component IN_LIST _merlin_known_components)
    set(Merlin_${_merlin_component}_FOUND FALSE)
  endif()
endforeach()

check_required_components(Merlin)
